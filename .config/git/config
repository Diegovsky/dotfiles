[include]
 path = common-info
 path = private

[safe]
	directory = /opt/flutter

[alias]
    c = commit
    s = switch
    st = status
    rc = rebase --continue
    lol = log --oneline
    ds = diff --stat
    A = add -A
	cp = cherry-pick
    cam = commit --amend --no-edit
    sync = !git pull && git push
    
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

