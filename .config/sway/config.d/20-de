set $menu bemenu-run
set $app_opener bemenu -i

# Launchers
bindsym $mod+d exec $menu

# DMS Keybindings
bindsym $mod+space exec dms ipc call spotlight toggle
bindsym $mod+comma exec dms ipc call settings focusOrToggle

# Audio controls
bindsym XF86AudioRaiseVolume exec dms ipc call audio increment 3
bindsym XF86AudioLowerVolume exec dms ipc call audio decrement 3

# Brightness controls
bindsym XF86MonBrightnessUp exec dms ipc call brightness increment 5
bindsym XF86MonBrightnessDown exec dms ipc call brightness decrement 5

# Sink volume toggle mute
bindsym XF86AudioMute exec dms ipc call audio mute
# Source volume toggle mute
bindsym F8 exec dms ipc call audio micmute
bindsym XF86AudioMicMute exec dms ipc call audio micmute

bindsym $mod+Up exec playerctl --player playerctld play-pause
bindsym $mod+Left exec playerctl --player playerctld previous
bindsym $mod+Right exec playerctl --player playerctld next
bindsym XF86AudioPlay exec playerctl --player playerctld play-pause
bindsym XF86AudioNext exec playerctl --player playerctld next
bindsym XF86AudioPrev exec playerctl --player playerctld previous
bindsym XF86AudioStop exec playerctl --player playerctld stop


bindsym Print exec $SHELL -c "sway-screenshot -m output"
bindsym Ctrl+Print exec $SHELL -c "sway-screenshot -m window"
bindsym Shift+Print exec $SHELL -c "sway-screenshot -m region"

# exec eval $(gnome-keyring-daemon --start)
exec 'while :; do dms run; done'
