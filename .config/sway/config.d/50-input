focus_follows_mouse always
input "type:keyboard" {
    repeat_delay 400
    repeat_rate 30
    xkb_layout "br"
    xkb_model "abnt2"
    xkb_variant ",abnt2"
}
input "type:tablet_tool" {
    map_to_output "HDMI-A-1"
}
input "type:pointer" {
    scroll_factor 1.0
    accel_profile flat
}
input "type:touchpad" {
    accel_profile adaptive
    scroll_method two_finger
    natural_scroll enabled
    tap enabled
}
