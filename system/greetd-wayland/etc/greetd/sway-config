exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK DBUS_SESSION_BUS_ADDRESS XAUTHORITY

exec "dbus-run-session -- gtkgreet -l --command '/usr/local/bin/launch-wayfire.sh'; swaymsg exit"

bindsym Mod4+Return exec alacritty
bindsym Mod4+q kill

bindsym Mod4+Space floating toggle

exec "alacritty -e systemctl --user status xdg-desktop-portal ; read"

bindsym Mod4+shift+e exec swaynag \
-t warning \
-m 'What do you want to do?' \
-b 'Poweroff' 'systemctl poweroff' \
-b 'Reboot' 'systemctl reboot'

input "type:keyboard" {
    xkb_layout "br"
}
