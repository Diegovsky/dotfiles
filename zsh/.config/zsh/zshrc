unset LC_MESSAGES
source /etc/locale.conf

if zmodload lua; then
    HAS_LUA=1
    zmodload lua
    lua-source "$ZDOTDIR/init.lua"
    alias lua=lua-eval
fi


# quck function to source scripts from zsh folder
function import() {
    if [[ $# -eq 0 ]]; then
        return
    fi
    source "$ZDOTDIR/$1"
    shift
    import $@
}

function lua-source() {
    if [[ -n "$HAS_LUA" ]]; then
        builtin lua-source $1
    fi
}

autoload -U add-zsh-hook

function meta::join() {
    local sep=$1
    shift
    eval "print \${(j.${sep}.)@}"
}

function meta::osc() {
    if [[ $# -eq 0 ]]; then
        print 'fail to osc' args: $@
    fi
    print -Pn "\e]$(meta::join ';' $@)\e\\"
}

function meta::osc7() {
    meta::osc 7 "file://$PWD"
}

# holds important functionality for other parts
import store.zsh

# PLUGINS
import etc.zsh zoxide.zsh direnv.zsh cursor_mode.zsh
import bindings.zsh prompt.zsh prompt_name.zsh aliases.zsh


add-zsh-hook chpwd meta::osc7

source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
