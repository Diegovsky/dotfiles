unset LC_MESSAGES
source /etc/locale.conf

if zmodload lua; then
    HAS_LUA=1
    zmodload lua
    lua-source "$ZDOTDIR/init.lua"
    alias lua=lua-eval
fi


# quck function to source scripts from zsh folder
function import() {
    if [[ $# -eq 0 ]]; then
        return
    fi
    source "$ZDOTDIR/$1"
    shift
    import $@
}

function lua-source() {
    if [[ -n "$HAS_LUA" ]]; then
        builtin lua-source $1
    fi
}


# holds important functionality for other parts
import store.zsh

# PLUGINS
import etc.zsh zoxide.zsh direnv.zsh cursor_mode.zsh
import bindings.zsh prompt.zsh prompt_name.zsh aliases.zsh

source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
